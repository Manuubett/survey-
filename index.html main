/* ══ CONSENT & RESEARCHER FLOW ══ */
function toggleProceed() { document.getElementById('proceedBtn').disabled = !document.getElementById('consentCheck').checked; }
function declineConsent() { document.getElementById('consentModal').classList.add('hidden'); document.getElementById('declinedMsg').style.display = 'block'; }
function proceedAfterConsent() {
  if(!document.getElementById('consentCheck').checked) return;
  document.getElementById('consentModal').classList.add('hidden');
  checkResearcher();
}
function checkResearcher() {
  const s = localStorage.getItem('ecs_researcher');
  if(s) { try { const r = JSON.parse(s); if(r.name && r.id) { showSurvey(r.name, r.id); return; } } catch(e) {} }
  document.getElementById('researcherModal').classList.remove('hidden');
}
function saveResearcher() {
  const name = document.getElementById('resName').value.trim();
  const id   = document.getElementById('resId').value.trim();
  let ok = true;
  document.getElementById('resNameErr').style.display = name ? 'none' : 'block'; if(!name) ok = false;
  document.getElementById('resIdErr').style.display   = id   ? 'none' : 'block'; if(!id)   ok = false;
  if(!ok) return;
  localStorage.setItem('ecs_researcher', JSON.stringify({ name, id }));
  document.getElementById('researcherModal').classList.add('hidden');
  showSurvey(name, id);
}
function showSurvey(name, id) {
  document.getElementById('bannerName').textContent = name;
  document.getElementById('bannerId').textContent   = id;
  document.getElementById('researcherBanner').style.display = 'flex';
  document.getElementById('surveyWrapper').style.display    = 'block';
  startGpsWatch(); attachAutosave(); refreshPendingUI(); checkForDraft();
  if(navigator.onLine && getQueue().length > 0) syncPendingNow();
  window.scrollTo({ top: 0 });
}
function changeResearcher() {
  if(watchId !== null) { navigator.geolocation.clearWatch(watchId); watchId = null; }
  localStorage.removeItem('ecs_researcher'); localStorage.removeItem('ecs_gps_last');
  document.getElementById('resName').value = ''; document.getElementById('resId').value = '';
  document.getElementById('surveyWrapper').style.display    = 'none';
  document.getElementById('researcherBanner').style.display = 'none';
  document.getElementById('gpsStatusBar').style.display     = 'none';
  document.getElementById('draftBar').style.display         = 'none';
  document.getElementById('researcherModal').classList.remove('hidden');
}
