/* ══ LIVE GPS WATCH ══ */
let watchId = null, livePos = null;
function startGpsWatch() {
  if(!navigator.geolocation) return;
  document.getElementById('gpsStatusBar').style.display = 'block';
  setGpsDot('acquiring', 'Acquiring signal…', null);
  watchId = navigator.geolocation.watchPosition(
    pos => {
      livePos = pos;
      const acc = Math.round(pos.coords.accuracy), good = acc <= GPS_CONFIG.MAX_ACCURACY_METERS;
      setGpsDot(good?'good':'poor', `${pos.coords.latitude.toFixed(5)}, ${pos.coords.longitude.toFixed(5)}`, acc);
      updateLiveDistanceChip(pos.coords.latitude, pos.coords.longitude);
      updateLocationBox(pos);
    },
    () => setGpsDot('poor', 'GPS unavailable', null),
    { enableHighAccuracy: true, maximumAge: 5000 }
  );
}

function updateLocationBox(pos) {
  const box = document.getElementById('locationBox');
  if(!pos) { box.style.display = 'none'; return; }
  box.style.display = 'block';
  document.getElementById('locLat').textContent = pos.coords.latitude.toFixed(6);
  document.getElementById('locLng').textContent = pos.coords.longitude.toFixed(6);
  const acc = Math.round(pos.coords.accuracy), good = acc <= GPS_CONFIG.MAX_ACCURACY_METERS;
  const el = document.getElementById('locAcc');
  el.textContent = `±${acc} m`; el.className = 'loc-acc '+(good?'good':'poor');
}

function setGpsDot(state, text, accuracy) {
  document.getElementById('gpsDot').className = 'gps-dot '+state;
  let html = text;
  if(accuracy !== null) {
    const cls = accuracy <= GPS_CONFIG.MAX_ACCURACY_METERS ? 'good' : 'poor';
    html += ` &nbsp;·&nbsp; Accuracy: <span class="loc-acc ${cls}">±${accuracy} m</span>`;
  }
  document.getElementById('gpsStatusText').innerHTML = html;
}

function updateLiveDistanceChip(lat, lng) {
  const chip   = document.getElementById('gpsDistanceChip');
  const banner = document.getElementById('proximityLockBanner');
  const lockMsg = document.getElementById('proximityLockMsg');
  const btn = document.getElementById('submitBtn');
  const last = getResRecord();

  /* No prior record = first survey; chip hidden, no lock */
  if(!last) {
    chip.style.display = 'none';
    banner.style.display = 'none';
    if(btn) btn.disabled = false;
    return;
  }

  const dist   = Math.round(haversineM(last.lat, last.lng, lat, lng));
  const distOk = dist >= GPS_CONFIG.MIN_DISTANCE_METERS;
  const timeOk = (Date.now() - last.ts) >= GPS_CONFIG.MIN_TIME_GAP_MS;

  chip.style.display = 'inline-block';
  if(distOk && timeOk) {
    chip.style.cssText += ';background:#dcfce7;color:#166534;border:1px solid #86efac';
    chip.textContent = '📍 Location OK';
  } else {
    chip.style.cssText += ';background:#fee2e2;color:#991b1b;border:1px solid #fca5a5';
    chip.textContent = distOk ? '⏱ Wait required' : '📍 Move to new location';
  }

  if(!distOk || !timeOk) {
    const wait = Math.ceil((GPS_CONFIG.MIN_TIME_GAP_MS - (Date.now() - last.ts)) / 1000);
    lockMsg.textContent = !distOk
      ? 'Please move to a different location before your next respondent.'
      : `Please wait ${wait} more second(s) before next submission.`;
    banner.style.display = 'block';
    if(btn) btn.disabled = true;
  } else {
    banner.style.display = 'none';
    if(btn) btn.disabled = false;
  }
}

/* ══ GPS GUARD MODAL ══ */
let pendingData = null;

function setStep(id, state, detail) {
  document.getElementById(id).className = state;
  const s = document.getElementById(id+'-detail'); if(s && detail) s.textContent = detail;
}
function setProgress(pct) { document.getElementById('gpsProgressBar').style.width = pct+'%'; }

/* ─────────────────────────────────────────────────────────────
   openGpsGuard()
   Detects whether this is the FIRST survey (no prior GPS record)
   and adjusts the modal title, note banner, and step labels.
───────────────────────────────────────────────────────────── */
function openGpsGuard(payload) {
  pendingData = payload;
  const isFirst = !getResRecord();

  /* Reset all steps */
  ['step-acquire','step-accuracy','step-distance','step-time'].forEach(id => {
    document.getElementById(id).className = '';
    const s = document.getElementById(id+'-detail'); if(s) s.textContent = '';
  });

  /* Subtitle and first-survey note */
  document.getElementById('gpsGuardSubtitle').textContent = isFirst
    ? 'Recording your starting location — please wait'
    : 'Verifying GPS before submitting — please wait';

  const note = document.getElementById('firstSurveyNote');
  note.style.display = isFirst ? 'block' : 'none';

  /* Step label updates */
  document.getElementById('step-accuracy-detail').textContent = isFirst
    ? 'Skipped on first survey — any fix accepted'
    : `Requires ≤ ${GPS_CONFIG.MAX_ACCURACY_METERS} m accuracy`;

  document.getElementById('step-distance-detail').textContent = isFirst
    ? 'Skipped — no prior location to compare'
    : 'Must be 500 m from last survey';

  document.getElementById('step-time-detail').textContent = isFirst
    ? 'Skipped — no prior survey to compare'
    : 'Checking time since last survey';

  setProgress(0);
  document.getElementById('liveGpsCard').style.display = 'none';
  document.getElementById('gpsRetryBtn').style.display = 'none';
  document.getElementById('gpsCancelBtn').textContent = 'Cancel';
  document.getElementById('gpsGuardModal').classList.remove('hidden');
  runGpsChecks();
}

function cancelGpsCheck() {
  document.getElementById('gpsGuardModal').classList.add('hidden');
  const btn = document.getElementById('submitBtn'); btn.disabled = false; btn.textContent = '📍 Submit Survey';
  pendingData = null;
}
function retryGpsCheck() { document.getElementById('gpsRetryBtn').style.display = 'none'; runGpsChecks(); }
function failGpsGuard(stepId, msg) {
  setStep(stepId, 'fail', msg);
  document.getElementById('gpsRetryBtn').style.display = 'inline-block';
  const btn = document.getElementById('submitBtn'); btn.disabled = false; btn.textContent = '📍 Submit Survey';
}

/* ── GPS CHECK CHAIN ── */
function runGpsChecks() {
  if(!navigator.geolocation) { failGpsGuard('step-acquire', 'GPS not supported on this device.'); return; }

  if(livePos && livePos.coords.accuracy <= GPS_CONFIG.MAX_ACCURACY_METERS) {
    setStep('step-acquire', 'active', 'Using live GPS fix…');
    setProgress(10);
    setTimeout(() => processGpsFix(livePos), 300);
    return;
  }

  setStep('step-acquire', 'active', 'Requesting high-accuracy GPS…');
  setProgress(10);

  const highAccTimer = setTimeout(() => {
    setStep('step-acquire', 'active', 'High-accuracy timed out → trying network GPS…');
    navigator.geolocation.getCurrentPosition(
      pos => processGpsFix(pos),
      err => handleGpsError(err),
      { enableHighAccuracy: false, timeout: GPS_CONFIG.LOW_ACC_TIMEOUT_MS, maximumAge: GPS_CONFIG.MAX_AGE_MS }
    );
  }, GPS_CONFIG.HIGH_ACC_TIMEOUT_MS);

  navigator.geolocation.getCurrentPosition(
    pos => { clearTimeout(highAccTimer); processGpsFix(pos); },
    err => {
      clearTimeout(highAccTimer);
      if(err.code === 3) {
        setStep('step-acquire', 'active', 'Switching to network GPS…');
        navigator.geolocation.getCurrentPosition(
          pos => processGpsFix(pos),
          err2 => handleGpsError(err2),
          { enableHighAccuracy: false, timeout: GPS_CONFIG.LOW_ACC_TIMEOUT_MS, maximumAge: GPS_CONFIG.MAX_AGE_MS }
        );
      } else { handleGpsError(err); }
    },
    { enableHighAccuracy: true, timeout: GPS_CONFIG.HIGH_ACC_TIMEOUT_MS, maximumAge: GPS_CONFIG.MAX_AGE_MS }
  );
}

function handleGpsError(err) {
  const msgs = {
    1: 'Location permission denied.\nPlease allow location access in your browser settings and retry.',
    2: 'GPS signal unavailable. Please go outside and retry.',
    3: 'Location timed out. Please move to an open area and tap Retry.'
  };
  failGpsGuard('step-acquire', msgs[err.code] || err.message);
}

/* ─────────────────────────────────────────────────────────────
   processGpsFix()

   FIRST survey  → accept any GPS fix regardless of accuracy.
                   Skip accuracy, distance and time checks.
                   Mark those steps as "skipped" (green tick).
                   Save the fix as the anchor point and submit.

   SUBSEQUENT    → run full accuracy + distance + time checks
                   exactly as before.
───────────────────────────────────────────────────────────── */
function processGpsFix(pos) {
  const lat = pos.coords.latitude, lng = pos.coords.longitude;
  const acc = Math.round(pos.coords.accuracy), now = Date.now();
  const isFirst = !getResRecord();

  /* Show live coords card */
  document.getElementById('liveGpsCoordsDisplay').textContent = `${lat.toFixed(6)}, ${lng.toFixed(6)}`;
  document.getElementById('liveGpsAccDisplay').textContent = `Accuracy: ±${acc} m`;
  document.getElementById('liveGpsCard').style.display = 'block';

  setStep('step-acquire', 'done', `${lat.toFixed(5)}, ${lng.toFixed(5)}`);
  setProgress(30);

  if(isFirst) {
    /* ── FIRST SURVEY: skip accuracy / distance / time ── */
    setStep('step-accuracy', 'skipped', '✓ Skipped — first survey');
    setStep('step-distance', 'skipped', '✓ Skipped — no prior location');
    setStep('step-time',     'skipped', '✓ Skipped — no prior survey');
    setProgress(100);

    pendingData.gps = { lat, lng, accuracy: acc };
    pendingData.submittedAt = new Date().toISOString();
    pendingData.timestamp = firebase.firestore.FieldValue.serverTimestamp();
    pendingData.firstSurvey = true;
    submitOrEnqueue(pendingData, lat, lng, now);
    return;
  }

  /* ── SUBSEQUENT SURVEYS: full checks ── */

  /* Accuracy check */
  setStep('step-accuracy', 'active', `Measured: ±${acc} m`);
  setProgress(50);
  if(acc > GPS_CONFIG.MAX_ACCURACY_METERS) {
    failGpsGuard('step-accuracy', `Accuracy too low (±${acc} m). Move outside and retry.`);
    return;
  }
  setStep('step-accuracy', 'done', `±${acc} m — OK`);
  setProgress(65);

  /* Distance check */
  setStep('step-distance', 'active', 'Checking previous location…');
  const last = getResRecord();
  const dist = Math.round(haversineM(last.lat, last.lng, lat, lng));
  if(dist < GPS_CONFIG.MIN_DISTANCE_METERS) {
    failGpsGuard('step-distance', `Too close to last survey location (${dist} m). Please move at least ${GPS_CONFIG.MIN_DISTANCE_METERS} m away.`);
    return;
  }
  setStep('step-distance', 'done', `${dist} m from last survey — OK`);
  setProgress(80);

  /* Time gap check */
  setStep('step-time', 'active', 'Checking time since last survey…');
  const elapsed = now - last.ts;
  if(elapsed < GPS_CONFIG.MIN_TIME_GAP_MS) {
    const wait = Math.ceil((GPS_CONFIG.MIN_TIME_GAP_MS - elapsed) / 1000);
    failGpsGuard('step-time', `Too soon. Please wait ${wait} more second(s).`);
    return;
  }
  setStep('step-time', 'done', `${Math.round(elapsed/1000)}s since last survey — OK`);
  setProgress(100);

  pendingData.gps = { lat, lng, accuracy: acc };
  pendingData.submittedAt = new Date().toISOString();
  pendingData.timestamp = firebase.firestore.FieldValue.serverTimestamp();
  pendingData.firstSurvey = false;
  submitOrEnqueue(pendingData, lat, lng, now);
}

/* ══ SUBMIT / ENQUEUE ══ */
function submitOrEnqueue(data, lat, lng, ts) {
  if(!navigator.onLine) {
    document.getElementById('gpsGuardModal').classList.add('hidden');
    enqueue(data); saveResRecord(lat, lng, ts); clearDraft();
    showStatus('offline', '📵 <strong>Offline — survey saved locally.</strong><br>Will upload automatically when you reconnect.');
    resetForm(); pendingData = null; return;
  }
  db.collection('responses').add(data)
    .then(() => {
      saveResRecord(lat, lng, ts); clearDraft();
      document.getElementById('gpsGuardModal').classList.add('hidden');
      showStatus('success', '✓ Survey submitted successfully. Thank you!');
      resetForm(); pendingData = null;
      window.scrollTo({ top: 0, behavior: 'smooth' });
    })
    .catch(err => {
      document.getElementById('gpsGuardModal').classList.add('hidden');
      enqueue(data); saveResRecord(lat, lng, ts); clearDraft();
      showStatus('offline', `📵 <strong>Upload failed — saved locally.</strong><br>${err.message}`);
      resetForm(); pendingData = null;
    });
}

function showStatus(cls, html) {
  const s = document.getElementById('status');
  s.className = 'status-msg '+cls; s.innerHTML = html; s.style.display = 'block';
}

function resetForm() {
  document.getElementById('surveyForm').reset();
  document.querySelectorAll('.gov-card').forEach(c => c.classList.remove('selected'));
  updateWards();
  const btn = document.getElementById('submitBtn'); btn.disabled = false; btn.textContent = '📍 Submit Survey';
  if(livePos) updateLiveDistanceChip(livePos.coords.latitude, livePos.coords.longitude);
}

