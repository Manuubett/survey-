    b.className = 'online'; b.innerHTML = '✅ Back online'; b.style.display = 'flex';
    setTimeout(() => b.style.display = 'none', 3000);
    if(getQueue().length > 0) setTimeout(syncPendingNow, 1500);
  }
}
