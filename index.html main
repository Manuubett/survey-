<!DOCTYPE html>
<html lang="en">
<head>
<title>Embu County Political Survey – ECS-2025</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta charset="UTF-8">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet">
<script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-firestore-compat.js"></script>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --navy:    #0f2547;
  --blue:    #1255cc;
  --sky:     #3b82f6;
  --green:   #16a34a;
  --amber:   #d97706;
  --red:     #dc2626;
  --bg:      #f4f6fb;
  --surface: #ffffff;
  --border:  #e2e8f4;
  --text:    #1e293b;
  --muted:   #64748b;
  --radius:  10px;
  --shadow:  0 2px 12px rgba(15,37,71,.08);
}
body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); line-height: 1.55; font-size: 14px; }

.site-header { background: linear-gradient(135deg, var(--navy) 0%, #1a3fa0 100%); color: #fff; padding: 32px 20px 24px; text-align: center; position: relative; overflow: hidden; }
.site-header::before { content: ''; position: absolute; inset: 0; background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E"); }
.site-header h1 { font-family: 'DM Serif Display', serif; font-size: clamp(20px, 5vw, 28px); letter-spacing: .5px; position: relative; }
.site-header p { font-size: 13px; opacity: .8; margin-top: 4px; position: relative; }
.header-badge { display: inline-block; margin-top: 12px; background: rgba(255,255,255,.15); border: 1px solid rgba(255,255,255,.3); padding: 4px 16px; border-radius: 20px; font-size: 11px; letter-spacing: 1.2px; text-transform: uppercase; position: relative; }
.header-actions { margin-top: 16px; position: relative; }
.header-btn { background: rgba(255,255,255,.18); border: 1.5px solid rgba(255,255,255,.4); color: #fff; padding: 8px 22px; border-radius: 24px; font-size: 13px; font-weight: 600; cursor: pointer; font-family: inherit; transition: all .2s; letter-spacing: .3px; }
.header-btn:hover { background: rgba(255,255,255,.28); }

.status-strip { background: var(--surface); border-bottom: 1px solid var(--border); padding: 8px 20px; display: none; }
.status-strip-inner { max-width: 780px; margin: 0 auto; display: flex; align-items: center; gap: 10px; flex-wrap: wrap; font-size: 12.5px; }
.gps-dot { width: 9px; height: 9px; border-radius: 50%; background: #bbb; flex-shrink: 0; transition: background .3s; }
.gps-dot.acquiring { background: var(--amber); animation: pulse 1.2s infinite; }
.gps-dot.good      { background: var(--green); }
.gps-dot.poor      { background: var(--red); }
@keyframes pulse { 0%,100%{opacity:1}50%{opacity:.35} }

#draftBar { display: none; position: sticky; top: 0; z-index: 200; background: #fffbeb; border-bottom: 2px solid #fcd34d; padding: 8px 16px; }
.draft-inner { max-width: 780px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; gap: 10px; flex-wrap: wrap; font-size: 13px; }
.draft-left { display: flex; align-items: center; gap: 8px; }
.draft-text { color: #78350f; font-weight: 600; }
.draft-sub  { color: #92400e; font-size: 11.5px; }
.draft-btn { font-size: 11.5px; font-weight: 700; padding: 5px 14px; border-radius: 20px; cursor: pointer; border: 1.5px solid; font-family: inherit; transition: all .15s; }
.draft-btn.restore { background: var(--blue); color: #fff; border-color: var(--blue); }
.draft-btn.discard { background: #fff; color: var(--red); border-color: #fca5a5; }

#proximityLockBanner { display: none; background: #fff1f2; border-bottom: 2px solid #fecdd3; padding: 9px 20px; position: sticky; top: 0; z-index: 199; }
.lock-inner { max-width: 780px; margin: 0 auto; display: flex; align-items: center; gap: 10px; font-size: 13px; color: #991b1b; font-weight: 600; }

#networkBadge { display: none; position: fixed; bottom: 20px; right: 20px; z-index: 999; padding: 10px 18px; border-radius: 30px; font-size: 13px; font-weight: 700; box-shadow: 0 4px 20px rgba(0,0,0,.2); pointer-events: none; transition: all .3s; align-items: center; gap: 7px; }
#networkBadge.offline { background: var(--red); color: #fff; display: flex; }
#networkBadge.online  { background: var(--green); color: #fff; display: flex; }

#autosaveIndicator { position: fixed; bottom: 72px; right: 20px; z-index: 998; font-size: 11.5px; color: #555; background: #fff; border: 1px solid var(--border); border-radius: 20px; padding: 5px 13px; box-shadow: var(--shadow); display: none; transition: opacity .4s; }

#surveyWrapper { display: none; }
.container { max-width: 780px; margin: 0 auto; padding: 22px 16px 60px; }

#researcherBanner { background: #f0fdf4; border: 1px solid #bbf7d0; border-left: 5px solid var(--green); border-radius: var(--radius); padding: 11px 16px; margin-bottom: 18px; display: none; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px; font-size: 13px; color: #166534; }
.res-action-btn { font-size: 11px; padding: 5px 13px; border: 1px solid var(--green); background: #fff; color: var(--green); border-radius: 20px; cursor: pointer; font-weight: 700; font-family: inherit; transition: all .15s; }
.res-action-btn:hover { background: var(--green); color: #fff; }
.res-action-btn.pending { background: var(--amber); color: #fff; border-color: var(--amber); }

#pendingBanner { display: none; background: #fef3c7; border: 1.5px solid #fcd34d; border-left: 5px solid var(--amber); border-radius: var(--radius); padding: 11px 16px; margin-bottom: 16px; font-size: 13px; color: #78350f; }
.sync-btn { display: inline-block; margin-top: 7px; background: var(--amber); color: #fff; border: none; border-radius: 20px; padding: 5px 18px; font-size: 12px; font-weight: 700; cursor: pointer; font-family: inherit; }

.card { background: var(--surface); border-radius: 12px; box-shadow: var(--shadow); margin-bottom: 22px; overflow: hidden; border: 1px solid var(--border); }
.card-head { background: linear-gradient(135deg, var(--navy), #1a3fa0); color: #fff; padding: 13px 20px; display: flex; align-items: center; gap: 12px; }
.card-head.green { background: linear-gradient(135deg, #166534, #16a34a); }
.section-badge { background: rgba(255,255,255,.2); border-radius: 50%; width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 13px; flex-shrink: 0; }
.card-head h3 { font-size: 13px; letter-spacing: .6px; text-transform: uppercase; font-weight: 600; }
.card-body { padding: 20px; }

.field { margin-bottom: 18px; }
.field:last-child { margin-bottom: 0; }
.field-label { display: block; font-weight: 600; font-size: 13px; color: var(--text); margin-bottom: 7px; }
.field-label .qn { color: var(--blue); margin-right: 4px; }
.field-note { font-size: 11px; color: var(--muted); font-style: italic; margin-left: 4px; }

select, input[type="text"], textarea { width: 100%; padding: 10px 13px; border: 1.5px solid var(--border); border-radius: 8px; font-size: 14px; background: #fafbff; color: var(--text); transition: border-color .2s, box-shadow .2s; font-family: inherit; }
select:focus, input[type="text"]:focus, textarea:focus { outline: none; border-color: var(--sky); background: #fff; box-shadow: 0 0 0 3px rgba(59,130,246,.12); }
textarea { min-height: 76px; resize: vertical; }

.pill-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 5px; }
.pill { position: relative; }
.pill input { position: absolute; opacity: 0; width: 0; height: 0; }
.pill label { display: inline-block; padding: 7px 15px; border: 1.5px solid var(--border); border-radius: 24px; font-size: 13px; cursor: pointer; color: var(--muted); background: #fafbff; transition: all .15s; user-select: none; }
.pill input:checked + label { background: var(--blue); color: #fff; border-color: var(--blue); font-weight: 600; }

.svc-table { width: 100%; border-collapse: collapse; font-size: 13px; }
.svc-table th, .svc-table td { padding: 9px 8px; border: 1px solid var(--border); text-align: center; }
.svc-table th { background: #eef2ff; color: var(--navy); font-size: 11.5px; font-weight: 600; }
.svc-table td:first-child { text-align: left; font-weight: 600; color: var(--text); }
.svc-table tr:nth-child(even) td { background: #fafbff; }
.svc-table input[type="radio"] { width: 16px; height: 16px; accent-color: var(--blue); cursor: pointer; }

.gov-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
@media(max-width:480px) { .gov-grid { grid-template-columns: 1fr; } }
.gov-card { border: 2px solid var(--border); border-radius: 10px; padding: 14px; cursor: pointer; transition: all .15s; text-align: center; }
.gov-card:hover { border-color: var(--sky); background: #f0f8ff; }
.gov-card.selected { border-color: var(--blue); background: #eef3ff; }
.gov-card input { display: none; }
.gov-card .gc-name { font-weight: 700; font-size: 14px; color: var(--navy); }
.gov-card .gc-tag  { font-size: 11px; color: var(--muted); margin-top: 3px; }

.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
@media(max-width:500px) { .two-col { grid-template-columns: 1fr; } }

.section-note { font-size: 12px; color: var(--muted); font-style: italic; margin-bottom: 13px; }
.opt-badge { display: inline-block; background: #f0fdf4; color: var(--green); font-size: 10.5px; font-weight: 700; padding: 2px 9px; border-radius: 10px; margin-left: 8px; }

.submit-wrap { margin-top: 8px; }
#submitBtn { width: 100%; padding: 15px; background: linear-gradient(135deg, var(--blue), var(--navy)); color: #fff; border: none; border-radius: 10px; font-size: 16px; font-weight: 700; cursor: pointer; letter-spacing: .4px; transition: opacity .2s; font-family: inherit; }
#submitBtn:disabled { opacity: .4; cursor: not-allowed; }
#submitBtn:not(:disabled):hover { opacity: .88; }

.status-msg { text-align: center; margin-top: 14px; font-size: 14px; font-weight: 600; padding: 11px 16px; border-radius: 8px; }
.status-msg.success { color: #166534; background: #dcfce7; border: 1px solid #86efac; }
.status-msg.error   { color: #991b1b; background: #fee2e2; border: 1px solid #fca5a5; }
.status-msg.warning { color: #92400e; background: #fef3c7; border: 1px solid #fcd34d; }
.status-msg.offline { color: #1e40af; background: #dbeafe; border: 1px solid #93c5fd; }

.loc-box { background: #f8faff; border: 1.5px solid #c7d7f9; border-radius: 10px; padding: 14px 16px; margin-top: 14px; font-size: 13px; }
.loc-box-head { font-weight: 700; color: var(--navy); margin-bottom: 8px; display: flex; align-items: center; gap: 8px; }
.loc-row { display: flex; flex-wrap: wrap; gap: 6px 16px; font-size: 12.5px; color: var(--muted); }
.loc-val { font-weight: 600; color: var(--text); }
.loc-acc { font-weight: 700; }
.loc-acc.good { color: var(--green); }
.loc-acc.poor { color: var(--red); }

.modal-overlay { position: fixed; inset: 0; background: rgba(10,20,50,.65); z-index: 1000; display: flex; align-items: center; justify-content: center; padding: 16px; backdrop-filter: blur(3px); }
.modal-overlay.hidden { display: none; }
.modal-box { background: #fff; border-radius: 16px; width: 100%; max-width: 660px; max-height: 92vh; overflow: hidden; display: flex; flex-direction: column; box-shadow: 0 32px 80px rgba(0,0,0,.25); animation: mIn .22s ease; }
@keyframes mIn { from{transform:scale(.93);opacity:0} to{transform:scale(1);opacity:1} }
.modal-head { background: linear-gradient(135deg, var(--navy), #1a3fa0); color: #fff; padding: 22px 26px; flex-shrink: 0; }
.modal-head h2 { font-size: 19px; font-family: 'DM Serif Display', serif; margin-bottom: 3px; }
.modal-head p  { font-size: 12px; opacity: .8; font-style: italic; }
.modal-scroll  { overflow-y: auto; padding: 22px 26px; flex: 1; }
.modal-foot    { padding: 16px 26px; border-top: 2px solid var(--border); background: #f8faff; flex-shrink: 0; }

.consent-h4 { color: var(--navy); font-size: 12.5px; text-transform: uppercase; letter-spacing: .5px; margin: 18px 0 6px; }
.consent-h4:first-child { margin-top: 0; }
.consent-section p, .consent-section li { font-size: 13px; color: #444; line-height: 1.75; margin: 2px 0; }
.consent-section ul { padding-left: 20px; margin: 4px 0; }
.consent-check { display: flex; align-items: flex-start; gap: 11px; margin-bottom: 18px; background: #fffbeb; border: 1px solid #fde68a; border-radius: 8px; padding: 13px 15px; }
.consent-check input[type="checkbox"] { width: 18px; height: 18px; margin-top: 2px; flex-shrink: 0; accent-color: var(--blue); cursor: pointer; }
.consent-check label { font-size: 13px; color: #333; font-weight: 600; cursor: pointer; line-height: 1.55; }
.btn-row { display: flex; gap: 10px; justify-content: flex-end; }
.btn-decline { padding: 10px 22px; border: 1.5px solid #ccc; border-radius: 8px; background: #fff; color: var(--muted); font-size: 14px; cursor: pointer; font-weight: 700; font-family: inherit; transition: all .15s; }
.btn-decline:hover { background: #f5f5f5; }
.btn-proceed { padding: 10px 28px; border: none; border-radius: 8px; background: linear-gradient(135deg, var(--blue), var(--navy)); color: #fff; font-size: 14px; cursor: pointer; font-weight: 700; font-family: inherit; transition: opacity .15s; }
.btn-proceed:disabled { opacity: .35; cursor: not-allowed; }
.btn-proceed:not(:disabled):hover { opacity: .88; }

.res-field { margin-bottom: 16px; }
.res-field label { display: block; font-weight: 600; font-size: 13px; color: var(--text); margin-bottom: 5px; }
.res-field input { width: 100%; padding: 11px 13px; border: 1.5px solid var(--border); border-radius: 8px; font-size: 14px; background: #fafbff; font-family: inherit; }
.res-field input:focus { outline: none; border-color: var(--sky); }
.res-err { color: #c62828; font-size: 12px; margin-top: 3px; display: none; }
.res-note { font-size: 13px; color: var(--muted); line-height: 1.65; margin-bottom: 20px; }

#gpsGuardModal .modal-box { max-width: 500px; }
.gps-steps { list-style: none; margin: 14px 0; }
.gps-steps li { display: flex; align-items: flex-start; gap: 13px; padding: 11px 13px; border-radius: 8px; margin-bottom: 8px; background: #f8faff; border: 1px solid #e2eaf8; font-size: 13px; color: var(--text); }
.gps-steps li.done   { background: #f0fdf4; border-color: #bbf7d0; }
.gps-steps li.active { background: #fffbeb; border-color: #fde68a; }
.gps-steps li.fail   { background: #fff1f2; border-color: #fecdd3; }
.gps-steps li.skipped { background: #f0fdf4; border-color: #bbf7d0; opacity: .65; }
.step-icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }
.step-text strong { display: block; font-size: 13px; font-weight: 600; margin-bottom: 1px; }
.step-text span   { font-size: 12px; color: var(--muted); }
.gps-prog { height: 4px; background: #e5e7eb; border-radius: 4px; overflow: hidden; margin: 14px 0 0; }
.gps-prog-bar { height: 100%; background: linear-gradient(90deg, var(--blue), var(--green)); border-radius: 4px; transition: width .4s; width: 0; }

/* first-survey info banner inside GPS modal */
.first-survey-note { background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 8px; padding: 11px 14px; margin-bottom: 14px; font-size: 13px; color: #1e40af; display: none; }
.first-survey-note strong { display: block; margin-bottom: 3px; }

.live-gps-card { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px; padding: 12px 14px; margin-top: 14px; font-size: 12.5px; }
.live-gps-card strong { color: var(--navy); display: block; margin-bottom: 6px; font-size: 13px; }
.gps-coords { font-family: monospace; font-size: 12px; color: #166534; margin: 2px 0; }

#offlineModal .modal-box { max-width: 500px; }
.q-list { max-height: 240px; overflow-y: auto; margin: 12px 0; }
.q-item { display: flex; align-items: center; justify-content: space-between; padding: 11px 13px; border-radius: 8px; margin-bottom: 8px; background: #fef3c7; border: 1px solid #fde68a; font-size: 13px; }
.q-item .qi-info { color: #78350f; }
.q-item .qi-time { font-size: 11px; color: #92400e; margin-top: 2px; }
.q-item .qi-del  { font-size: 18px; cursor: pointer; color: var(--red); padding: 0 4px; border: none; background: none; }
.sync-prog-wrap { margin: 12px 0; display: none; }
.sync-prog-outer { height: 6px; background: #e5e7eb; border-radius: 6px; overflow: hidden; }
.sync-prog-inner { height: 100%; background: linear-gradient(90deg, var(--blue), var(--green)); border-radius: 6px; transition: width .4s; width: 0; }
.sync-status { font-size: 12px; color: var(--muted); margin-top: 6px; text-align: center; }

#declinedMsg { display: none; text-align: center; padding: 70px 20px; }
#gpsDistanceChip { display: none; margin-left: auto; font-size: 11.5px; font-weight: 700; padding: 3px 11px; border-radius: 12px; }
</style>
</head>
<body>

<!-- CONSENT MODAL -->
<div class="modal-overlay" id="consentModal">
  <div class="modal-box">
    <div class="modal-head">
      <h2>📋 Informed Consent</h2>
      <p>Embu County Political &amp; Service Delivery Survey · ECS-2025 · Please read carefully</p>
    </div>
    <div class="modal-scroll">
      <div class="consent-section">
        <div class="consent-h4">1. Purpose of This Research</div>
        <p>You are invited to participate in a research study examining political participation, governance, service delivery, and development priorities in Embu County. Findings will inform policy discussions and community development planning.</p>
        <div class="consent-h4">2. What Participation Involves</div>
        <p>Your participation involves completing a questionnaire covering:</p>
        <ul>
          <li>Your demographic background (age, gender, location, education, employment)</li>
          <li>Political participation and civic engagement</li>
          <li>Opinions on local government transparency and accountability</li>
          <li>Assessment of public service delivery (health, education, agriculture, infrastructure)</li>
          <li>Economic challenges and development priorities in your ward</li>
          <li>Sentiment and preferences regarding county leadership</li>
        </ul>
        <div class="consent-h4">3. Duration</div>
        <p>Completing this questionnaire takes approximately <strong>20–35 minutes</strong>.</p>
        <div class="consent-h4">4. Voluntary Participation</div>
        <p>Participation is entirely voluntary. You may decline any question and may withdraw at any time without negative consequences.</p>
        <div class="consent-h4">5. Confidentiality &amp; Data Protection</div>
        <ul>
          <li>All information is kept strictly confidential.</li>
          <li>Responses will be anonymised and cannot be traced to you individually.</li>
          <li>Data is stored securely, accessible only to authorised research personnel.</li>
          <li>Aggregated findings may be published; no individual data will be disclosed.</li>
          <li>Contact information (if provided) is stored separately from survey responses.</li>
          <li>Your data will be handled per applicable data protection laws.</li>
          <li><strong>GPS coordinates</strong> are collected only to verify geographic coverage and prevent duplicate submissions — not to identify individuals.</li>
        </ul>
        <div class="consent-h4">6. Risks &amp; Benefits</div>
        <p>There are no known risks. Your contribution ensures community voices are represented in Embu County governance and policy-making.</p>
      </div>
    </div>
    <div class="modal-foot">
      <div class="consent-check">
        <input type="checkbox" id="consentCheck" onchange="toggleProceed()">
        <label for="consentCheck">I have read and understood the above. I voluntarily agree to participate and consent to data collection including GPS location for quality assurance purposes.</label>
      </div>
      <div class="btn-row">
        <button class="btn-decline" onclick="declineConsent()">Decline</button>
        <button class="btn-proceed" id="proceedBtn" disabled onclick="proceedAfterConsent()">I Agree &amp; Continue →</button>
      </div>
    </div>
  </div>
</div>

<!-- RESEARCHER MODAL -->
<div class="modal-overlay hidden" id="researcherModal">
  <div class="modal-box" style="max-width:480px;">
    <div class="modal-head">
      <h2>👤 Researcher Registration</h2>
      <p>First-time setup — saved on this device</p>
    </div>
    <div class="modal-scroll">
      <p class="res-note">Enter your name and researcher ID. These are saved locally so you don't need to re-enter them, and are attached to each submission for quality assurance.</p>
      <div class="res-field">
        <label for="resName">Full Name *</label>
        <input type="text" id="resName" placeholder="e.g. Jane Muthoni Kariuki" autocomplete="off">
        <div class="res-err" id="resNameErr">Please enter your full name.</div>
      </div>
      <div class="res-field">
        <label for="resId">Researcher / Enumerator ID *</label>
        <input type="text" id="resId" placeholder="e.g. ECS-R-001" autocomplete="off">
        <div class="res-err" id="resIdErr">Please enter your researcher ID.</div>
      </div>
    </div>
    <div class="modal-foot">
      <div class="btn-row">
        <button class="btn-proceed" onclick="saveResearcher()">Save &amp; Start Survey →</button>
      </div>
    </div>
  </div>
</div>

<!-- GPS GUARD MODAL -->
<div class="modal-overlay hidden" id="gpsGuardModal">
  <div class="modal-box" style="max-width:480px;">
    <div class="modal-head">
      <h2>📍 Location Verification</h2>
      <p id="gpsGuardSubtitle">Capturing GPS location — please wait</p>
    </div>
    <div class="modal-scroll">
      <!-- shown only on first survey -->
      <div class="first-survey-note" id="firstSurveyNote">
        <strong>📌 First survey of the day</strong>
        Your starting location is being recorded. From the next survey onwards, the system will check that you have moved to a new location before submitting.
      </div>

      <ul class="gps-steps">
        <li id="step-acquire" class="active">
          <span class="step-icon">🛰️</span>
