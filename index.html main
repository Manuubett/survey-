}

function saveResRecord(lat, lng, ts) {
  localStorage.setItem('ecs_gps_last', JSON.stringify({ lat, lng, ts, day: getTodayKey() }));
}

function haversineM(lat1, lng1, lat2, lng2) {
  const R = 6371000, dLat = (lat2-lat1)*Math.PI/180, dLng = (lng2-lng1)*Math.PI/180;
  const a = Math.sin(dLat/2)**2 + Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLng/2)**2;
  return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
}

function getChecked(ids) {
  return ids.filter(id => { const e = document.getElementById(id); return e && e.checked; }).map(id => document.getElementById(id).value);
}

/* ══ DRAFT / AUTOSAVE ══ */
const DRAFT_KEY = 'ecs_form_draft', QUEUE_KEY = 'ecs_offline_queue';
let autosaveTimer = null;

function collectSnap() {
  const s = {};
  document.querySelectorAll('input[type="radio"]').forEach(r => { if(r.checked) s[r.name] = r.value; });
  document.querySelectorAll('input[type="checkbox"]').forEach(cb => { s['cb_'+cb.id] = cb.checked; });
  document.querySelectorAll('input[type="text"],textarea,select').forEach(el => { s[el.id] = el.value; });
  s._savedAt = new Date().toISOString(); return s;
}
function applySnap(s) {
  if(!s) return;
  document.querySelectorAll('input[type="radio"]').forEach(r => { if(s[r.name]!==undefined) r.checked=(r.value===s[r.name]); });
  document.querySelectorAll('input[type="checkbox"]').forEach(cb => { if(s['cb_'+cb.id]!==undefined) cb.checked=s['cb_'+cb.id]; });
  document.querySelectorAll('input[type="text"],textarea,select').forEach(el => { if(s[el.id]!==undefined) el.value=s[el.id]; });
  updateWards(true);
  const gv = s['governor'];
  if(gv) document.querySelectorAll('.gov-card').forEach(c => { const r = c.querySelector('input[type="radio"]'); if(r&&r.value===gv) c.classList.add('selected'); });
  updateNegativeQuestions();
}
function saveDraft() { localStorage.setItem(DRAFT_KEY, JSON.stringify(collectSnap())); showAutoSave(); }
function clearDraft() { localStorage.removeItem(DRAFT_KEY); }
function loadDraft() { try { return JSON.parse(localStorage.getItem(DRAFT_KEY)||'null'); } catch(e) { return null; } }
function showAutoSave() {
  const el = document.getElementById('autosaveIndicator');
  el.style.display = 'block'; el.style.opacity = '1';
  clearTimeout(el._t);
  el._t = setTimeout(() => { el.style.opacity = '0'; setTimeout(() => el.style.display = 'none', 400); }, 2200);
}
function checkForDraft() {
  const d = loadDraft(); if(!d) return;
  const dt = new Date(d._savedAt);
  document.getElementById('draftSubText').textContent = 'Last saved: '+dt.toLocaleDateString()+' '+dt.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
  document.getElementById('draftBar').style.display = 'block';
}
function restoreDraft() { applySnap(loadDraft()); document.getElementById('draftBar').style.display = 'none'; showAutoSave(); }
function discardDraft() {
  if(!confirm('Discard the saved draft and start fresh?')) return;
  clearDraft(); document.getElementById('draftBar').style.display = 'none';
}
function attachAutosave() {
  const f = document.getElementById('surveyForm');
  f.addEventListener('input',  () => { clearTimeout(autosaveTimer); autosaveTimer = setTimeout(saveDraft, 1500); });
  f.addEventListener('change', () => { clearTimeout(autosaveTimer); autosaveTimer = setTimeout(saveDraft, 1500); });
}

/* ══ OFFLINE QUEUE ══ */
function getQueue() { try { return JSON.parse(localStorage.getItem(QUEUE_KEY)||'[]'); } catch(e) { return []; } }
function saveQueue(q) { localStorage.setItem(QUEUE_KEY, JSON.stringify(q)); }
function enqueue(d) { d._queuedAt = new Date().toISOString(); d._queueId = 'q_'+Date.now()+'_'+Math.random().toString(36).slice(2,7); const q = getQueue(); q.push(d); saveQueue(q); refreshPendingUI(); }
function dequeue(id) { saveQueue(getQueue().filter(d => d._queueId !== id)); refreshPendingUI(); }
function refreshPendingUI() {
  const n = getQueue().length;
  document.getElementById('pendingQueueBtn').style.display = n > 0 ? 'inline-block' : 'none';
  document.getElementById('pendingBanner').style.display   = n > 0 ? 'block'        : 'none';
  const ct = document.getElementById('pendingCountText');  if(ct) ct.textContent = n;
  const cb = document.getElementById('pendingCountBadge'); if(cb) cb.textContent = n;
}
function openOfflineModal()  { renderQueueList(); document.getElementById('offlineModal').classList.remove('hidden'); }
function closeOfflineModal() { document.getElementById('offlineModal').classList.add('hidden'); }
function renderQueueList() {
  const q = getQueue(), el = document.getElementById('queueList');
  if(!q.length) { el.innerHTML = '<p style="color:var(--muted);font-size:13px;text-align:center;padding:12px;">No pending submissions.</p>'; return; }
  el.innerHTML = q.map((item,i) => {
    const t = new Date(item._queuedAt);
    return `<div class="q-item"><div class="qi-info"><div>Survey #${i+1} — ${item.constituency||'?'}, ${item.ward||'?'}</div><div class="qi-time">⏱ Queued: ${t.toLocaleDateString()} ${t.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})}</div></div><button class="qi-del" onclick="removeQueueItem('${item._queueId}')">🗑</button></div>`;
  }).join('');
}
function removeQueueItem(id) { if(!confirm('Remove this queued survey?')) return; dequeue(id); renderQueueList(); }
async function syncPendingNow() {
  if(!navigator.onLine) { alert('Still offline. Please connect first.'); return; }
  const q = getQueue(); if(!q.length) { closeOfflineModal(); return; }
  const btn = document.getElementById('syncNowBtn');
  const wrap = document.getElementById('syncProgressWrap'), bar = document.getElementById('syncProgressBar'), txt = document.getElementById('syncStatusText');
  btn.disabled = true; wrap.style.display = 'block';
  let done = 0, errs = [];
  for(const item of q) {
    try {
      txt.textContent = `Uploading ${done+1} of ${q.length}…`;
      bar.style.width = Math.round(done/q.length*100)+'%';
      const {_queuedAt, _queueId, ...fd} = item;
      fd.offlineQueuedAt = _queuedAt;
      await db.collection('responses').add(fd);
      dequeue(item._queueId); done++;
      bar.style.width = Math.round(done/q.length*100)+'%';
    } catch(e) { errs.push(item._queueId); }
  }
  btn.disabled = false; wrap.style.display = 'none'; renderQueueList(); refreshPendingUI();
  if(!errs.length) { alert(`✅ All ${done} survey(s) uploaded!`); closeOfflineModal(); }
  else alert(`⚠️ ${done} uploaded, ${errs.length} failed. Please retry.`);
}

/* ══ NETWORK ══ */
